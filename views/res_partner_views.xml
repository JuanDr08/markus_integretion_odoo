<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_markus" model="ir.ui.view">
        <field name="name">res.partner.form.markus</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="inside">
                <group name="markus_fiscal_data" string="Datos Fiscales Markus">
                    <field name="markus_regimen_fiscal"/>
                    <field name="markus_responsabilidad"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
